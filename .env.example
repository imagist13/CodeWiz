# ============================================================
# CodeWiz - Environment Configuration Template
# ============================================================
# Copy to .env and configure for production
# IMPORTANT: Change all SECRET values before deploying!

# ===================
# Database
# ===================
POSTGRES_DB=codewiz
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ===================
# JWT Secret (Backend + AI Service)
# ===================
JWT_SECRET=CHANGE_THIS_WITH_32CHAR_RANDOM_STRING

# ===================
# Backend (Go)
# ===================
BACKEND_SERVER_PORT=8080
BACKEND_CORS_ORIGINS=*

# ===================
# AI Service (Python FastAPI)
# ===================
# Get API key from: https://cloud.siliconflow.cn
SILICON_FLOW_API_KEY=YOUR_SILICON_FLOW_API_KEY

# LLM Model options:
# - Qwen/Qwen2.5-7B-Instruct (fastest, 7B params)
# - Qwen/Qwen2.5-14B-Instruct (balanced, 14B params)
# - Qwen/Qwen3-Coder-30B-A3B-Instruct (coding focused, 30B params)
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

AI_SERVICE_URL=http://ai-service:8000

# ===================
# Frontend (Next.js)
# ===================
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_AI_SERVICE_URL=/ai/api
