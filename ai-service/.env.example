# CodeWiz AI Service Environment Configuration
# Copy to .env and configure for production

# Application
APP_NAME=CodeWiz AI Service
DEBUG=false

# Database
DATABASE_URL=host=localhost user=postgres password=postgres dbname=adorable port=5432 sslmode=disable

# JWT Secret - MUST match Go backend
JWT_SECRET=adorable-dev-secret-change-in-prod

# Go Backend URL (internal service name in Docker)
BACKEND_URL=http://backend:8080

# Silicon Flow LLM Configuration
# Get your API key from: https://cloud.siliconflow.cn
SILICON_FLOW_API_URL=https://api.siliconflow.cn/v1
SILICON_FLOW_API_KEY=your-api-key-here
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# File Storage
UPLOAD_DIR=./uploads