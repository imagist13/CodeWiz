# CodeWiz Backend Environment Configuration
# Copy to .env and configure for production

# Server
SERVER_PORT=8080

# Database (libpq format - supported natively)
DATABASE_URL=host=localhost user=postgres password=postgres dbname=adorable port=5432 sslmode=disable

# JWT Secret - MUST be changed in production
JWT_SECRET=adorable-dev-secret-change-in-prod

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000